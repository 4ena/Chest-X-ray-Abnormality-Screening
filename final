<button class="arrow arrow-left" id="arrowLeft">&#8249;</button>
<button class="arrow arrow-right" id="arrowRight">&#8250;</button>

<div class="dots" id="dots"></div>

<div class="progress-track"><div class="progress-fill" id="progressFill"></div></div>

<script>
(function() {
  const AUTOPLAY_MS = 13000;

  const slides = document.querySelectorAll('.slide');
  const TOTAL = slides.length;
  let current = 0;
  let paused = false;
  let timer = null;
  let deckStartTime = Date.now();

  const dotsEl = document.getElementById('dots');
  const counter = document.getElementById('counter');
  const btnPause = document.getElementById('btnPause');
  const progressFill = document.getElementById('progressFill');
  const timerDisplay = document.getElementById('timerDisplay');

  document.documentElement.style.setProperty('--autoplay-ms', AUTOPLAY_MS + 'ms');

  const totalTime = TOTAL * AUTOPLAY_MS;
  const totalTimeFormatted = formatTime(totalTime);

  /* ── particles ── */
  const particlesEl = document.getElementById('particles');
  for (let i = 0; i < 35; i++) {
    const p = document.createElement('div');
    p.className = 'particle';
    const size = Math.random() * 3 + 1;
    p.style.cssText =
      'left:' + (Math.random()*100) + '%;' +
      'top:' + (Math.random()*100) + '%;' +
      'width:' + size + 'px;' +
      'height:' + size + 'px;' +
      'animation:floatUp ' + (Math.random()*22+14) + 's linear ' + (Math.random()*-20) + 's infinite;';
    particlesEl.appendChild(p);
  }

  /* ── dots ── */
  for (let i = 0; i < TOTAL; i++) {
    var d = document.createElement('button');
    d.className = 'dot' + (i === 0 ? ' active' : '');
    d.setAttribute('data-dot', i);
    d.addEventListener('click', (function(idx) {
      return function() { goTo(idx); };
    })(i));
    dotsEl.appendChild(d);
  }

  function pad(n) { return String(n).padStart(2, '0'); }

  function formatTime(ms) {
    var s = Math.floor(ms / 1000);
    return Math.floor(s / 60) + ':' + pad(s % 60);
  }

  function updateDots() {
    var dots = dotsEl.querySelectorAll('.dot');
    for (var i = 0; i < dots.length; i++) {
      dots[i].className = 'dot' + (i === current ? ' active' : '');
    }
  }

  function updateCounter() {
    counter.textContent = pad(current + 1) + ' / ' + pad(TOTAL);
  }

  function updateTimer() {
    var elapsed = Date.now() - deckStartTime;
    timerDisplay.textContent = formatTime(elapsed) + ' / ' + totalTimeFormatted;
  }

  function resetProgress() {
    progressFill.classList.remove('animating');
    void progressFill.offsetWidth;
    if (!paused) progressFill.classList.add('animating');
  }

  function showSlide(index) {
    for (var i = 0; i < slides.length; i++) {
      slides[i].classList.remove('active', 'visible');
    }
    slides[index].classList.add('active');
    void slides[index].offsetWidth;
    requestAnimationFrame(function() { slides[index].classList.add('visible'); });
    updateDots();
    updateCounter();
    resetProgress();
  }

  function goTo(index) {
    slides[current].classList.remove('visible');
    clearTimeout(timer);
    setTimeout(function() {
      current = index;
      showSlide(current);
      scheduleNext();
    }, 350);
  }

  function next() { goTo((current + 1) % TOTAL); }
  function prev() { goTo((current - 1 + TOTAL) % TOTAL); }

  function scheduleNext() {
    clearTimeout(timer);
    if (!paused) timer = setTimeout(next, AUTOPLAY_MS);
  }

  function togglePause() {
    paused = !paused;
    btnPause.textContent = paused ? '\u25B6 PLAY' : '\u275A\u275A PAUSE';
    if (paused) {
      clearTimeout(timer);
      progressFill.classList.remove('animating');
    } else {
      resetProgress();
      scheduleNext();
    }
  }

  /* ── controls ── */
  document.getElementById('arrowRight').addEventListener('click', next);
  document.getElementById('arrowLeft').addEventListener('click', prev);
  btnPause.addEventListener('click', togglePause);

  document.addEventListener('keydown', function(e) {
    if (e.key === 'ArrowRight' || e.key === ' ') { e.preventDefault(); next(); }
    if (e.key === 'ArrowLeft') { e.preventDefault(); prev(); }
    if (e.key === 'p' || e.key === 'P') togglePause();
  });

  /* ── timer tick ── */
  setInterval(updateTimer, 500);

  /* ── init ── */
  showSlide(0);
  scheduleNext();
})();
</script>
